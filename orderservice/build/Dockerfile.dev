FROM golang:1.25-alpine AS builder

WORKDIR /app/build

COPY api/ /app/api
COPY shared/ /app/shared

COPY orderservice/go.mod orderservice/go.sum ./
RUN go mod download

COPY orderservice/ .
RUN go build -o app ./cmd

FROM alpine:latest AS build

WORKDIR /app

COPY --from=builder /app/build/app .

RUN chmod +x ./app

CMD ["./app"]